---
import "../styles/gallery.css";
import PhotoCard from "../components/PhotoCard.astro";
import type { UnsplashPhoto } from "../components/PhotoCard.astro";
import Vibrant from "node-vibrant";
import fs from "node:fs";
import path from "node:path";

// Fetch from Unsplash at build time
const accessKey = import.meta.env.UNSPLASH_ACCESS_KEY;
if (!accessKey) {
  throw new Error("UNSPLASH_ACCESS_KEY is required in .env");
}

const COLLECTION_ID = "0kF7vQfhbTA";
const CACHE_PATH = path.join(process.cwd(), "src/data/photos-cache.json");

let photos: UnsplashPhoto[] = [];
let usedCache = false;

// Try to load from cache in development
if (import.meta.env.DEV && fs.existsSync(CACHE_PATH)) {
  try {
    const cacheData = fs.readFileSync(CACHE_PATH, "utf-8");
    photos = JSON.parse(cacheData);
    usedCache = true;
    console.log("[Unsplash] Using local cache to save API credits.");
  } catch (e) {
    console.warn("[Unsplash] Failed to read cache, falling back to API.");
  }
}

if (!usedCache) {
  console.log("[Unsplash] Fetching fresh data from API...");
  // Fetch up to 30 photos from the collection
  const res = await fetch(
    `https://api.unsplash.com/collections/${COLLECTION_ID}/photos?per_page=30&client_id=${accessKey}`,
  );

  if (!res.ok) {
    throw new Error(`Failed to fetch Unsplash collection: ${res.statusText}`);
  }

  const collectionPhotos = await res.json();

  // The /collections endpoint returns 'simplified' photo objects missing full EXIF and location.
  // We must make a secondary request for each ID to get the full metadata.
  photos = await Promise.all(
    collectionPhotos.map(async (simplifiedPhoto: any) => {
      let finalPhoto = simplifiedPhoto;
      try {
        const detailRes = await fetch(
          `https://api.unsplash.com/photos/${simplifiedPhoto.id}?client_id=${accessKey}`,
        );
        if (detailRes.ok) {
          finalPhoto = await detailRes.json();
        }
      } catch (e) {
        console.warn(`Failed to fetch full details for ${simplifiedPhoto.id}`);
      }

      // Impactful Color Extraction:
      try {
        const imageRes = await fetch(finalPhoto.urls.small);
        if (!imageRes.ok)
          throw new Error(
            `Failed to fetch small image: ${imageRes.statusText}`,
          );
        const imageBuffer = Buffer.from(await imageRes.arrayBuffer());

        const palette = await Vibrant.from(imageBuffer).getPalette();

        const extractedColor =
          palette.Vibrant?.getHex() ||
          palette.DarkVibrant?.getHex() ||
          palette.Muted?.getHex() ||
          palette.LightVibrant?.getHex() ||
          palette.DarkMuted?.getHex() ||
          finalPhoto.color;

        finalPhoto.color = extractedColor;
      } catch (e) {
        console.warn(
          `Failed to extract vibrant color for ${finalPhoto.id}: ${e instanceof Error ? e.message : "Unknown error"}. Falling back to default: ${finalPhoto.color}`,
        );
      }

      // Clean up the object to only keep what's needed for the UI
      return {
        id: finalPhoto.id,
        created_at: finalPhoto.created_at,
        description: finalPhoto.description,
        alt_description: finalPhoto.alt_description,
        color: finalPhoto.color,
        urls: {
          full: finalPhoto.urls.full,
          small: finalPhoto.urls.small, // helpful for future logic
        },
        links: {
          html: finalPhoto.links.html,
          download_location: finalPhoto.links.download_location,
        },
        width: finalPhoto.width,
        height: finalPhoto.height,
        location: {
          name: finalPhoto.location?.name || null,
        },
        exif: {
          make: finalPhoto.exif?.make || null,
          model: finalPhoto.exif?.model || null,
          focal_length: finalPhoto.exif?.focal_length || null,
          aperture: finalPhoto.exif?.aperture || null,
          exposure_time: finalPhoto.exif?.exposure_time || null,
          iso: finalPhoto.exif?.iso || null,
        },
      } as UnsplashPhoto;
    }),
  );

  // Sort photos by date (newest first) before caching
  photos.sort(
    (a, b) =>
      new Date(b.created_at).getTime() - new Date(a.created_at).getTime(),
  );

  // Save to cache for future development runs
  try {
    if (!fs.existsSync(path.dirname(CACHE_PATH))) {
      fs.mkdirSync(path.dirname(CACHE_PATH), { recursive: true });
    }
    fs.writeFileSync(CACHE_PATH, JSON.stringify(photos, null, 2));
    console.log("[Unsplash] Cache updated successfully.");
  } catch (e) {
    console.warn("[Unsplash] Failed to write cache:", e);
  }
}

// Apply first photo color to hero section if it exists
const firstPhotoColor = photos.length > 0 ? photos[0].color : null;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon-light.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Photos | Pantoine.com</title>
    <meta
      name="description"
      content="A curated gallery of photographs by Antoine Pouligny, presented in a minimalist digital art exhibition format."
    />
    <meta property="og:title" content="Photos Pantoine - Antoine Pouligny" />
    <meta
      property="og:description"
      content="A curated gallery of photographs by Antoine Pouligny, presented in a minimalist digital art exhibition format."
    />
    {
      photos.length > 0 && (
        <meta property="og:image" content={photos[0].urls.full} />
      )
    }
    <meta property="og:type" content="website" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&family=Syne:wght@700;800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <main class="scroll-container" id="scrollContainer">
      <!-- Hero Title Screen -->
      <section class="section hero" data-color="#ffffff">
        <div class="portfolio-pill-container">
          <a
            href="https://www.pantoine.com/"
            target="_blank"
            rel="noopener noreferrer"
            class="portfolio-pill"
          >
            <svg
              width="16"
              height="16"
              viewBox="12.7 17.8 37 37"
              xmlns="http://www.w3.org/2000/svg"
              fill="currentColor"
            >
              <path
                d="M 31.2344 54.7305 C 31.8438 54.7305 32.2891 54.2852 32.4062 53.6524 C 34.0703 40.8086 35.8750 38.8633 48.5781 37.4570 C 49.2344 37.3867 49.6797 36.8945 49.6797 36.2852 C 49.6797 35.6758 49.2344 35.2070 48.5781 35.1133 C 35.8750 33.7070 34.0703 31.7617 32.4062 18.9180 C 32.2891 18.2852 31.8438 17.8633 31.2344 17.8633 C 30.6250 17.8633 30.1797 18.2852 30.0860 18.9180 C 28.4219 31.7617 26.5938 33.7070 13.9140 35.1133 C 13.2344 35.2070 12.7891 35.6758 12.7891 36.2852 C 12.7891 36.8945 13.2344 37.3867 13.9140 37.4570 C 26.5703 39.1211 28.3281 40.8321 30.0860 53.6524 C 30.1797 54.2852 30.6250 54.7305 31.2344 54.7305 Z"
              ></path>
            </svg>
            <span class="portfolio-pill-text">Check my Portfolio</span>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              class="portfolio-pill-arrow"
            >
              <line x1="5" y1="12" x2="19" y2="12"></line>
              <polyline points="12 5 19 12 12 19"></polyline>
            </svg>
          </a>
        </div>
        <div class="marquee-container">
          <div class="marquee-content">
            <h1>
              photos.pantoine.com.photos.pantoine.com.photos.pantoine.com.photos.pantoine.com.photos.pantoine.com.photos.pantoine.com.
            </h1>
            <!-- Content duplicated for seamless looping -->
            <h1 aria-hidden="true">
              photos.pantoine.com.photos.pantoine.com.photos.pantoine.com.photos.pantoine.com.photos.pantoine.com.photos.pantoine.com.
            </h1>
          </div>
        </div>
        <p>
          All photos by <a
            href="https://unsplash.com/@gimmick?utm_source=Pantoine_Photos&utm_medium=referral"
            target="_blank"
            rel="noopener noreferrer">Antoine Pouligny</a
          >, on <a
            href="https://unsplash.com/?utm_source=Pantoine_Photos&utm_medium=referral"
            target="_blank"
            rel="noopener noreferrer">Unsplash</a
          >
        </p>

        <button
          class="scroll-indicator"
          id="scrollIndicator"
          aria-label="Scroll down"
        >
          <svg
            width="32"
            height="32"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <polyline points="6 9 12 15 18 9"></polyline>
          </svg>
        </button>
      </section>

      <!-- Philosophy Section -->
      <section class="section philosophy" data-color="#ffffff">
        <div class="philosophy-card">
          <div class="card-header">
            <span class="card-ref">INFO-01</span>
            <h2>DISCLAIMER</h2>
          </div>

          <div class="card-body">
            <p>This website is a curated space for my photography.</p>
            <p>
              A digital exhibition designed for the patient observer. Please
              take your time.
            </p>
          </div>

          <div class="card-footer">
            <div class="instruction-row">
              <span class="label">NAVIGATE</span>
              <span class="value">SCROLL // KEYS</span>
            </div>
            <div class="instruction-row">
              <span class="label">OBSERVE</span>
              <span class="value">LOOK 5 SEC TO UNLOCK INFO</span>
            </div>
          </div>
        </div>
      </section>

      {
        photos.map((photo, i) => (
          <section class="section" data-color={photo.color}>
            <PhotoCard photo={photo} index={i} totalPhotos={photos.length} />
          </section>
        ))
      }

      <!-- Footer Screen -->
      <section class="section footer" id="footerSection">
        <h2>THANK YOU.</h2>
        <p class="subtitle">
          Interested in a print? <a href="mailto:a.pouligny@gmail.com"
            >Contact me at a.pouligny@gmail.com</a
          >
        </p>
        <p class="small-subtitle">
          If you haven't had enough, go have a look at my <a
            href="https://unsplash.com/@gimmick?utm_source=Pantoine_Photos&utm_medium=referral"
            target="_blank"
            rel="noopener noreferrer">Unsplash profile</a
          >.
        </p>

        <button class="back-to-top" id="backToTop" aria-label="Back to top">
          <svg
            width="32"
            height="32"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <polyline points="18 15 12 9 6 15"></polyline>
          </svg>
          <span>TOP</span>
        </button>
      </section>
    </main>

    <script src="../scripts/gallery-interactions.ts"></script>
  </body>
</html>
