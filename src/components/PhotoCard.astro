---
import { formatResolution, formatDate } from "../utils/formatters";

export interface UnsplashPhoto {
  id: string;
  created_at: string;
  description: string | null;
  alt_description: string | null;
  color: string;
  urls: {
    full: string;
  };
  links: {
    html: string;
    download_location: string;
  };
  width: number;
  height: number;
  location?: {
    name: string | null;
  };
  exif?: {
    make: string | null;
    model: string | null;
    focal_length: string | null;
    aperture: string | null;
    exposure_time: string | null;
    iso: number | null;
  };
}

interface Props {
  photo: UnsplashPhoto;
  index: number;
  totalPhotos: number;
}

const { photo, index, totalPhotos } = Astro.props;
---

<div class="image-container">
    <div class="artwork-wrapper">
      <div class="artwork-frame">
        <img
          src={photo.urls.full}
          alt={photo.alt_description || `Art photograph ${index + 1}`}
          class="photo"
          crossorigin="anonymous"
          loading={index === 0 ? "eager" : "lazy"}
          data-download-url={photo.links?.download_location}
          data-color={photo.color}
        />
      </div>

      <a
        href={`${photo.links.html}?utm_source=Pantoine_Photos&utm_medium=referral`}
        target="_blank"
        rel="noopener noreferrer"
        class="artwork-info-board"
      >
        <span class="artwork-counter">{index + 1} / {totalPhotos}</span>
        <p class="artwork-description">
          {
            photo.description ||
              photo.alt_description ||
              "A beautiful moment captured."
          }
        </p>
        <p class="artwork-meta">
          {formatDate(photo.created_at)}
          {photo.location?.name && ` \u2014 ${photo.location.name}`}
        </p>
        <p class="artwork-exif">
          {
            [
              photo.exif?.make && photo.exif?.model
                ? `${photo.exif.make} ${photo.exif.model}`
                : null,
              photo.exif?.focal_length ? `${photo.exif.focal_length}mm` : null,
              photo.exif?.aperture ? `f/${photo.exif.aperture}` : null,
              photo.exif?.exposure_time ? `${photo.exif.exposure_time}s` : null,
              photo.exif?.iso ? `ISO ${photo.exif.iso}` : null,
              formatResolution(photo.width, photo.height),
            ]
              .filter(Boolean)
              .join(" \u2022 ")
          }
        </p>
      </a>
    </div>
  </div>
